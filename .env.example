DELTA_API_KEY=YOUR_DELTA_API_KEY
DELTA_API_SECRET=YOUR_DELTA_API_SECRET
DELTA_TESTNET=false

# FIX-DRY-RUN: true = use your REAL API key + REAL live prices, but every
# entry/exit/bracket call is simulated in Python and NEVER sent to Delta.
# Use this when testnet API keys aren't working. No real money is ever at risk.
# Set back to false when you're ready to go live.
DRY_RUN=true
SYMBOL=BTC/USD:USD
ALERT_QTY=33
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
CANDLE_TIMEFRAME=30m
FILTER_ATR_MULT=1.4
FILTER_BODY_MULT=0.5
ADX_TREND_TH=23
ADX_RANGE_TH=18
ADX_TOLERANCE=0.5
TREND_RR=4.0
RANGE_RR=2.5
TREND_ATR_MULT=0.6
RANGE_ATR_MULT=0.5
MAX_SL_MULT=1.5
MAX_SL_POINTS=500
BE_MULT=0.6
BRACKET_SL_BUFFER=10.0
RSI_OB=70
RSI_OS=30

# FIX-PROFIT-FILTER: minimum ATR required before any signal fires.
# Raise this to trade less often but with higher expected profit per trade.
# Lower it (or set 0) to go back to trading every signal like before.
MIN_ATR_FOR_ENTRY=250

# FIX-PROFIT-FILTER: set to false to stop taking Range Long/Range Short
# trades entirely. Trend trades are unaffected either way.
RANGE_SIGNALS_ENABLED=true
PINE_MINTICK=0.5
TRAIL_LOOP_SEC=0.1
TRAIL_SL_PRE_FIRE_BUFFER=0
TRAIL_OFFSET_FLOOR_MULT=0.0
TRAIL_ARM_FLOOR_MULT=0.0
TRAIL_SL_CONFIRM_TICKS=1
SL_CONFIRM_TICKS=5
SL_CONFIRM_MS=1500
BAR_CLOSE_SL_EVAL=false
FILTER_VOL_MULT=1.0
FILTER_VOL_ENABLED=true
FILTER_BODY_TOLERANCE=0.0
BREAKOUT_BUFFER_PTS=0
TIME_EXIT_MINUTES=0
USE_BINANCE_FEED=true
BINANCE_SIGNAL_FEED=false
BINANCE_SYMBOL=BTC/USDT
POSITION_BTC_SIZE=0.033
SL_FIRE_VIA_BRACKET=false
LOG_FILE=/root/Bot-v10/journal.db
PORT=10000
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=9000
DASHBOARD_USER=admin
DASHBOARD_PASS=YOUR_DASHBOARD_PASSWORD
CLIENT_DASHBOARD_PORT=8081
TURSO_URL=libsql://YOUR_DB_NAME.aws-ap-south-1.turso.io
TURSO_TOKEN=YOUR_TURSO_TOKEN
GSHEET_SPREADSHEET_ID=YOUR_SPREADSHEET_ID
GSHEET_CREDENTIALS_JSON={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"YOUR_SA@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
